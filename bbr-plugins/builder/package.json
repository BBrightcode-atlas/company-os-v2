{
  "name": "paperclip-plugin-builder",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Blueprint, Wireframe, Project Builder를 하나의 Builder 흐름으로 제공하는 BBR 전용 Paperclip 플러그인",
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": [
    "paperclip",
    "plugin",
    "builder",
    "blueprint",
    "wireframe",
    "product-builder"
  ],
  "author": "BBrightCode",
  "license": "MIT",
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-select": "^2.3.1",
    "@tiptap/markdown": "3.27.1",
    "@tiptap/react": "3.27.1",
    "@tiptap/starter-kit": "3.27.1",
    "@tiptap/suggestion": "3.27.1",
    "@xyflow/react": "^12.11.1",
    "jszip": "^3.10.1",
    "lucide-react": "0.574.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.15.0",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "file:.paperclip-sdk/sdk-v2.tgz",
    "@paperclipai/shared": "file:.paperclip-sdk/shared-v2.tgz",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "esbuild": "^0.27.3",
    "rollup": "^4.38.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "files": [
    "dist",
    "migrations",
    "templates",
    "README.md"
  ],
  "pnpm": {
    "overrides": {
      "@paperclipai/shared": "file:.paperclip-sdk/shared-v2.tgz",
      "@paperclipai/shared@0.3.1": "file:.paperclip-sdk/shared-v2.tgz"
    }
  }
}
