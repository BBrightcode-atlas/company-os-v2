{
  "name": "paperclip-plugin-contract-issuer",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "표준 도급계약서 양식 기반 계약서 생성·발행 (AI 빈칸 작성 + 댓글 보완)",
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": [
    "paperclip",
    "plugin",
    "ui"
  ],
  "author": "BBrightCode",
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "@paperclipai/shared": "file:.paperclip-sdk/shared-v2.tgz",
      "@paperclipai/shared@0.3.1": "file:.paperclip-sdk/shared-v2.tgz"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@paperclipai/shared": "file:.paperclip-sdk/shared-v2.tgz",
    "@paperclipai/plugin-sdk": "file:.paperclip-sdk/sdk-v2.tgz",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "esbuild": "^0.27.3",
    "rollup": "^4.38.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "files": [
    "dist",
    "migrations"
  ]
}