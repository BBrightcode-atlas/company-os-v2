{
  "name": "paperclip-plugin-portfolio",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Project portfolio overview for Paperclip companies",
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4178",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": [
    "paperclip",
    "plugin",
    "portfolio"
  ],
  "author": "BBrightCode",
  "license": "MIT",
  "devDependencies": {
    "@paperclipai/plugin-sdk": "file:.paperclip-sdk/sdk-v2.tgz",
    "@paperclipai/shared": "file:.paperclip-sdk/shared-v2.tgz",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.3",
    "jsdom": "^29.1.1",
    "react-dom": "^19.2.7",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
